{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ultra-builder-pro.dev/spec/tasks.v4.5.schema.json",
  "title": "tasks.json projection (v4.5)",
  "description": "Read-only projection of the tasks table. Generated by the projector (Phase 2.6) — manual edits are overwritten. Status and dependencies are derived from state.db; do not write them through this file. Trace: PLAN §7.1, D21, D32.",
  "type": "object",
  "required": ["schema_version", "generated_at", "tasks"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "4.5" },
    "generated_at":   { "type": "string", "format": "date-time" },
    "source":         { "const": ".ultra/state.db", "description": "authoritative source (D32)" },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["id", "title", "type", "priority", "status", "created_at", "updated_at"],
      "additionalProperties": false,
      "properties": {
        "id":         { "type": "string", "pattern": "^[a-zA-Z0-9_\\-]+$" },
        "title":      { "type": "string", "minLength": 3 },
        "type":       { "type": "string", "enum": ["architecture", "feature", "bugfix"] },
        "priority":   { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
        "complexity": { "type": "integer", "minimum": 1, "maximum": 10 },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "completed", "blocked", "expanded"],
          "x-derived": true,
          "description": "DERIVED from state.db tasks.status; never write through this projection"
        },
        "deps": {
          "type": "array",
          "items": { "type": "string" },
          "x-derived": true,
          "description": "DERIVED from state.db tasks.deps JSON"
        },
        "files_modified": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Phase 8B conflict surface; new in v4.5"
        },
        "session_id": {
          "type": "string",
          "x-derived": true,
          "description": "DERIVED from state.db tasks.session_id (current owning session)"
        },
        "stale": {
          "type": "boolean",
          "x-derived": true,
          "description": "DERIVED from staleness propagation (Phase 5.3)"
        },
        "complexity_hint": { "type": "string", "enum": ["haiku", "sonnet", "opus"] },
        "tag":              { "type": "string" },
        "trace_to":         { "type": "string" },
        "context_file":     { "type": "string" },
        "completion_commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
        "created_at":       { "type": "string", "format": "date-time" },
        "updated_at":       { "type": "string", "format": "date-time" }
      }
    }
  }
}
