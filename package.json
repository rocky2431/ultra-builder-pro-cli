{
  "name": "ultra-builder-pro-cli",
  "version": "0.1.0",
  "description": "Multi-runtime installer for the Ultra Builder Pro (Hermes) agent engineering system — deploys commands, agents, skills, and hooks to Claude Code, OpenCode, Codex CLI, and Gemini CLI.",
  "bin": {
    "ultra-builder-pro-cli": "bin/install.js",
    "ubp": "bin/install.js"
  },
  "files": [
    "bin",
    "adapters",
    "ultra-tools",
    "commands",
    "agents",
    "skills",
    "hooks/*.py",
    "output-styles",
    "CLAUDE.md",
    "settings.json",
    ".ultra-template",
    "docs/ROADMAP.md"
  ],
  "keywords": [
    "claude-code",
    "opencode",
    "codex",
    "gemini",
    "agent",
    "cli",
    "multi-runtime",
    "hermes",
    "ultra-builder-pro",
    "meta-prompting",
    "context-engineering"
  ],
  "author": "Ultra Builder Pro contributors",
  "license": "MIT",
  "homepage": "https://github.com/rocky2431/ultra-builder-pro-cli",
  "bugs": {
    "url": "https://github.com/rocky2431/ultra-builder-pro-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rocky2431/ultra-builder-pro-cli.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "test": "node --test ultra-tools/*.test.cjs || true",
    "test:state": "node --test 'mcp-server/**/*.test.cjs'",
    "test:orch": "node --test 'orchestrator/**/*.test.cjs'",
    "test:spec": "node spec/scripts/test-all.cjs",
    "install:claude": "node bin/install.js --claude --local",
    "install:all": "node bin/install.js --all --local"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^11.5.0",
    "js-yaml": "^4.1.0"
  }
}
